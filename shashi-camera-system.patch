+
+function setCameraFilter(filterName){
+activeCameraFilter = filterName;
+const filter = cameraFilters[filterName] || cameraFilters.none;
+const video = byId('cameraVideo');
+const preview = byId('cameraPreview');
+
+if(video){
+video.style.filter = filter;
+}
+
+if(preview){
+preview.style.filter = filter;
+}
+
+document.querySelectorAll('.filter-btn').forEach((button)=>{
+button.classList.toggle('active', button.dataset.filter === filterName);
+});
+}
+
+function capturePhoto(){
+const video = byId('cameraVideo');
+const canvas = byId('cameraCanvas');
+
+if(!cameraStream || !video.videoWidth){
+alert('Camera is not ready yet.');
+return;
+}
+
+canvas.width = video.videoWidth;
+canvas.height = video.videoHeight;
+const ctx = canvas.getContext('2d');
+ctx.filter = cameraFilters[activeCameraFilter] || 'none';
+ctx.drawImage(video, 0, 0, canvas.width, canvas.height);
+
+capturedMedia = {
+messageType: 'image',
+mediaType: 'image/jpeg',
+mediaUrl: canvas.toDataURL('image/jpeg', 0.9),
+filter: activeCameraFilter,
+text: 'Photo'
+};
+
+renderCapturedPreview();
+}
+
+function toggleRecording(){
+if(!cameraStream){
+alert('Open camera first.');
+return;
+}
+
+if(mediaRecorder && mediaRecorder.state === 'recording'){
+mediaRecorder.stop();
+return;
+}
+
+recordedChunks = [];
+mediaRecorder = new MediaRecorder(cameraStream, {
+mimeType: MediaRecorder.isTypeSupported('video/webm;codecs=vp9')
+? 'video/webm;codecs=vp9'
+: 'video/webm'
+});
+
+mediaRecorder.ondataavailable = (event)=>{
+if(event.data.size > 0){
+recordedChunks.push(event.data);
+}
+};
+
+mediaRecorder.onstop = ()=>{
+const blob = new Blob(recordedChunks, { type: mediaRecorder.mimeType });
+const reader = new FileReader();
+reader.onload = ()=>{
+capturedMedia = {
+messageType: 'video',
+mediaType: blob.type,
+mediaUrl: reader.result,
+filter: activeCameraFilter,
+text: 'Video'
+};
+renderCapturedPreview();
+byId('recordButton').innerHTML = '<i class="fa-solid fa-circle"></i> Record';
+byId('cameraStatus').innerText = 'Video ready';
+};
+reader.readAsDataURL(blob);
+};
+
+mediaRecorder.start();
+byId('recordButton').innerHTML = '<i class="fa-solid fa-stop"></i> Stop';
+byId('cameraStatus').innerText = 'Recording...';
+}
+
+function renderCapturedPreview(){
+const preview = byId('cameraPreview');
+preview.classList.remove('hidden');
+
+if(capturedMedia.messageType === 'image'){
+preview.innerHTML = `<img src="${capturedMedia.mediaUrl}" alt="Captured photo">`;
+}else{
+preview.innerHTML = `<video src="${capturedMedia.mediaUrl}" controls></video>`;
+}
+
+setCameraFilter(activeCameraFilter);
+byId('sendMediaButton').disabled = false;
+byId('cameraStatus').innerText = `${capturedMedia.messageType === 'image' ? 'Photo' : 'Video'} ready`;
+}
+
+function clearCapturedMedia(){
+capturedMedia = null;
+const preview = byId('cameraPreview');
+if(preview){
+preview.innerHTML = '';
+preview.classList.add('hidden');
+preview.style.filter = cameraFilters[activeCameraFilter] || 'none';
+}
+const sendButton = byId('sendMediaButton');
+if(sendButton){
+sendButton.disabled = true;
+}
+}
