PORT=5000
NODE_ENV=production

# Use MongoDB Atlas for public hosting.
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/dutya

# Use a long random value. Minimum 32 characters.
JWT_SECRET=replace_with_a_long_random_secret

# Public frontend URL. Add more URLs separated by commas if needed.
CLIENT_ORIGIN=https://your-frontend-url.netlify.app

# Cloud storage. Cloudinary is ready after these two values are set.
STORAGE_PROVIDER=cloudinary
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_UPLOAD_PRESET=your_unsigned_upload_preset

# Android/Firebase push notifications.
# Use either GOOGLE_APPLICATION_CREDENTIALS or FIREBASE_CONFIG on the backend.
GOOGLE_APPLICATION_CREDENTIALS=/secure/path/firebase-service-account.json
FIREBASE_CONFIG=

# Optional storage providers. Leave empty unless you use them.
FIREBASE_STORAGE_BUCKET=
AWS_REGION=
AWS_S3_BUCKET=

# Optional upload limits.
BODY_LIMIT=25mb
MAX_UPLOAD_DATA_URL_LENGTH=12582912
